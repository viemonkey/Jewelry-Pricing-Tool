# .env — Backend environment variables
# Copy file này thành .env và điền thông tin thật

# MongoDB connection string
# Local:   mongodb://localhost:27017/jewelry-pricing
# Atlas:   mongodb+srv://user:pass@cluster.mongodb.net/jewelry-pricing
MONGODB_URI=mongodb://localhost:27017/jewelry-pricing

# Port cho NestJS backend
PORT=3001

# URL của Frontend (cho CORS)
FE_URL=http://localhost:3000
